{
  "name": "codetune-monorepo",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead'); process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./apps/**\" --if-present run typecheck",
    "build:web": "pnpm --filter @codetune/web run build",
    "build:api": "pnpm --filter @codetune/api run build",
    "dev:web": "pnpm --filter @codetune/web run dev",
    "dev:api": "pnpm --filter @codetune/api run dev",
    "db:push": "pnpm --filter @codetune/database run push",
    "db:push-force": "pnpm --filter @codetune/database run push-force"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
